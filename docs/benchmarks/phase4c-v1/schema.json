{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngx-powgate.invalid/schema/phase4c-benchmark-v1.json",
  "title": "PowGate Phase 4C browser benchmark evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "tested_source",
    "environment",
    "workload",
    "runs",
    "summaries",
    "decision",
    "verdicts"
  ],
  "properties": {
    "schema_version": {
      "const": "phase4c-benchmark-v1"
    },
    "generated_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "tested_source": {
      "$ref": "#/$defs/tested_source"
    },
    "environment": {
      "$ref": "#/$defs/environment"
    },
    "workload": {
      "$ref": "#/$defs/workload"
    },
    "runs": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "$ref": "#/$defs/run"
      }
    },
    "summaries": {
      "type": "object",
      "additionalProperties": false,
      "required": ["js", "subtle"],
      "properties": {
        "js": {
          "$ref": "#/$defs/summary"
        },
        "subtle": {
          "$ref": "#/$defs/summary"
        }
      }
    },
    "decision": {
      "$ref": "#/$defs/decision"
    },
    "verdicts": {
      "$ref": "#/$defs/verdicts"
    }
  },
  "$defs": {
    "sha256_hex": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nonnegative_number": {
      "type": "number",
      "minimum": 0
    },
    "positive_integer": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "tested_source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commit",
        "worktree_clean",
        "promotable",
        "evidence_commit",
        "tracked_tree_sha256",
        "production_script_sha256",
        "assembled_benchmark_page_sha256",
        "generated_csp_hash",
        "benchmark_implementation_sha256",
        "generator_sha256"
      ],
      "properties": {
        "commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "worktree_clean": {
          "type": "boolean"
        },
        "promotable": {
          "type": "boolean"
        },
        "evidence_commit": {
          "type": "null"
        },
        "tracked_tree_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "production_script_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "assembled_benchmark_page_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "generated_csp_hash": {
          "type": "string",
          "pattern": "^sha256-[A-Za-z0-9+/]{43}=$"
        },
        "benchmark_implementation_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "generator_sha256": {
          "$ref": "#/$defs/sha256_hex"
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_architecture",
        "container_architecture",
        "debian_snapshot",
        "debian_base_image_digest",
        "chromium_package_version",
        "chromium_package_sha256",
        "chromium_sandbox_package_version",
        "chromium_sandbox_package_sha256",
        "chromium_cdp_version",
        "nodejs_package_version",
        "nodejs_package_sha256",
        "npm_package_version",
        "npm_package_sha256",
        "puppeteer_core_version",
        "ajv_version",
        "ajv_integrity",
        "nginx_version",
        "nginx_package_version",
        "nginx_package_sha256",
        "kernel_version",
        "podman_version",
        "cpu_model",
        "logical_cpu_count",
        "requested_chromium_arguments",
        "observed_chromium_arguments",
        "uid_mapping_passed",
        "gid_mapping_passed",
        "seccomp_passed",
        "capabilities_passed",
        "sandbox_passed",
        "rootless_passed",
        "embedded_image_lock",
        "oci_image_lock",
        "host_image_id",
        "repository_digest"
      ],
      "properties": {
        "host_architecture": {
          "const": "x86_64"
        },
        "container_architecture": {
          "const": "x86_64"
        },
        "debian_snapshot": {
          "const": "20260713T000000Z"
        },
        "debian_base_image_digest": {
          "type": "string",
          "pattern": "^docker\\.io/library/debian@sha256:[0-9a-f]{64}$"
        },
        "chromium_package_version": {
          "const": "150.0.7871.100-1~deb13u1"
        },
        "chromium_package_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "chromium_sandbox_package_version": {
          "const": "150.0.7871.100-1~deb13u1"
        },
        "chromium_sandbox_package_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "chromium_cdp_version": {
          "type": "string",
          "minLength": 1
        },
        "nodejs_package_version": {
          "const": "20.19.2+dfsg-1+deb13u2"
        },
        "nodejs_package_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "npm_package_version": {
          "const": "9.2.0~ds1-3"
        },
        "npm_package_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "puppeteer_core_version": {
          "const": "24.43.1"
        },
        "ajv_version": {
          "const": "8.17.1"
        },
        "ajv_integrity": {
          "const": "sha512-B/gBuNg5SiMTrPkC+A2+cW0RszwxYmn6VYxB/inlBStS5nx6xHIt/ehKRhIMhqusl7a8LjQoZnjCs5vhwxOQ1g=="
        },
        "nginx_version": {
          "const": "1.30.3"
        },
        "nginx_package_version": {
          "const": "1.30.3-1~trixie"
        },
        "nginx_package_sha256": {
          "$ref": "#/$defs/sha256_hex"
        },
        "kernel_version": {
          "type": "string",
          "minLength": 1
        },
        "podman_version": {
          "type": "string",
          "minLength": 1
        },
        "cpu_model": {
          "type": "string",
          "minLength": 1
        },
        "logical_cpu_count": {
          "$ref": "#/$defs/positive_integer"
        },
        "requested_chromium_arguments": {
          "$ref": "#/$defs/string_array"
        },
        "observed_chromium_arguments": {
          "$ref": "#/$defs/string_array"
        },
        "uid_mapping_passed": {
          "type": "boolean"
        },
        "gid_mapping_passed": {
          "type": "boolean"
        },
        "seccomp_passed": {
          "type": "boolean"
        },
        "capabilities_passed": {
          "type": "boolean"
        },
        "sandbox_passed": {
          "type": "boolean"
        },
        "rootless_passed": {
          "type": "boolean"
        },
        "embedded_image_lock": {
          "$ref": "#/$defs/sha256_hex"
        },
        "oci_image_lock": {
          "$ref": "#/$defs/sha256_hex"
        },
        "host_image_id": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "repository_digest": {
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "string_array": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "type": "string"
      }
    },
    "workload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nonce_base64url",
        "difficulty",
        "warmup_duration_ms",
        "stopping_deadline_ms",
        "repetitions_per_backend",
        "execution_order",
        "heartbeat_period_ms",
        "heartbeat_p95_bound_ms",
        "heartbeat_max_bound_ms",
        "heartbeat_allowed_tail_callbacks",
        "js_block_ceiling_ms",
        "calibration_min_attempts",
        "calibration_max_attempts",
        "calibration_target_ms",
        "counter_start",
        "counter_progression_rule",
        "success_continuation_rule",
        "safe_domain_terminal_rule",
        "median_rule",
        "backend_selection_ratio",
        "matched_pair_wins_required"
      ],
      "properties": {
        "nonce_base64url": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        },
        "difficulty": {
          "const": 32
        },
        "warmup_duration_ms": {
          "const": 2000
        },
        "stopping_deadline_ms": {
          "const": 10000
        },
        "repetitions_per_backend": {
          "const": 7
        },
        "execution_order": {
          "type": "array",
          "minItems": 14,
          "maxItems": 14,
          "prefixItems": [
            { "const": "js" },
            { "const": "subtle" },
            { "const": "subtle" },
            { "const": "js" },
            { "const": "js" },
            { "const": "subtle" },
            { "const": "subtle" },
            { "const": "js" },
            { "const": "js" },
            { "const": "subtle" },
            { "const": "subtle" },
            { "const": "js" },
            { "const": "js" },
            { "const": "subtle" }
          ],
          "items": false
        },
        "heartbeat_period_ms": {
          "const": 5
        },
        "heartbeat_p95_bound_ms": {
          "const": 25
        },
        "heartbeat_max_bound_ms": {
          "const": 100
        },
        "heartbeat_allowed_tail_callbacks": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4
        },
        "js_block_ceiling_ms": {
          "const": 25
        },
        "calibration_min_attempts": {
          "$ref": "#/$defs/positive_integer"
        },
        "calibration_max_attempts": {
          "$ref": "#/$defs/positive_integer"
        },
        "calibration_target_ms": {
          "const": 10
        },
        "counter_start": {
          "const": 0
        },
        "counter_progression_rule": {
          "const": "contiguous-safe-integers"
        },
        "success_continuation_rule": {
          "const": "verified-counter-plus-one"
        },
        "safe_domain_terminal_rule": {
          "const": "max-safe-integer-stops-run"
        },
        "median_rule": {
          "const": "sorted-fourth-of-seven"
        },
        "backend_selection_ratio": {
          "const": 1.25
        },
        "matched_pair_wins_required": {
          "const": 5
        }
      }
    },
    "heartbeat_sample": {
      "type": "object",
      "additionalProperties": false,
      "required": ["deadline_performance_ms", "delay_ms"],
      "properties": {
        "deadline_performance_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "delay_ms": {
          "$ref": "#/$defs/nonnegative_number"
        }
      }
    },
    "number_series": {
      "type": "array",
      "maxItems": 8192,
      "items": {
        "$ref": "#/$defs/nonnegative_number"
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "backend",
        "pair",
        "execution_position",
        "calibrated_attempt_limit",
        "warmup_duration_ms",
        "recorded_start_performance_ms",
        "recorded_end_performance_ms",
        "completed_candidates",
        "valid_hit_count",
        "first_valid_hit_offset",
        "safe_domain_terminal",
        "elapsed_ms",
        "deadline_overrun_ms",
        "throughput_candidates_per_second",
        "heartbeat_samples",
        "heartbeat_p95_ms",
        "heartbeat_max_ms",
        "js_block_durations_ms",
        "subtle_sync_entry_durations_ms",
        "subtle_awaited_invocation_durations_ms",
        "subtle_async_remainder_durations_ms",
        "document_visible",
        "counter_contiguous",
        "correctness_passed",
        "context_cleanup_passed"
      ],
      "properties": {
        "backend": {
          "enum": ["js", "subtle"]
        },
        "pair": {
          "type": "integer",
          "minimum": 1,
          "maximum": 7
        },
        "execution_position": {
          "type": "integer",
          "minimum": 1,
          "maximum": 2
        },
        "calibrated_attempt_limit": {
          "$ref": "#/$defs/positive_integer"
        },
        "warmup_duration_ms": {
          "const": 2000
        },
        "recorded_start_performance_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "recorded_end_performance_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "completed_candidates": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "valid_hit_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1024
        },
        "first_valid_hit_offset": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            {
              "type": "null"
            }
          ]
        },
        "safe_domain_terminal": {
          "type": "boolean"
        },
        "elapsed_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "deadline_overrun_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "throughput_candidates_per_second": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "heartbeat_samples": {
          "type": "array",
          "minItems": 1,
          "maxItems": 8192,
          "items": {
            "$ref": "#/$defs/heartbeat_sample"
          }
        },
        "heartbeat_p95_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "heartbeat_max_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "js_block_durations_ms": {
          "$ref": "#/$defs/number_series"
        },
        "subtle_sync_entry_durations_ms": {
          "$ref": "#/$defs/number_series"
        },
        "subtle_awaited_invocation_durations_ms": {
          "$ref": "#/$defs/number_series"
        },
        "subtle_async_remainder_durations_ms": {
          "$ref": "#/$defs/number_series"
        },
        "document_visible": {
          "type": "boolean"
        },
        "counter_contiguous": {
          "type": "boolean"
        },
        "correctness_passed": {
          "type": "boolean"
        },
        "context_cleanup_passed": {
          "type": "boolean"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "throughput_values",
        "median_throughput",
        "heartbeat_max_ms",
        "heartbeat_p95_max_ms",
        "max_js_block_ms",
        "matched_pair_wins",
        "correctness_passed",
        "responsiveness_passed"
      ],
      "properties": {
        "throughput_values": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": {
            "$ref": "#/$defs/nonnegative_number"
          }
        },
        "median_throughput": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "heartbeat_max_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "heartbeat_p95_max_ms": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "max_js_block_ms": {
          "anyOf": [
            {
              "$ref": "#/$defs/nonnegative_number"
            },
            {
              "type": "null"
            }
          ]
        },
        "matched_pair_wins": {
          "type": "integer",
          "minimum": 0,
          "maximum": 7
        },
        "correctness_passed": {
          "type": "boolean"
        },
        "responsiveness_passed": {
          "type": "boolean"
        }
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selected_primary_backend",
        "selected_secondary_backend",
        "subtle_to_js_median_ratio",
        "ratio_threshold_met",
        "matched_pair_requirement_met",
        "prerequisites_met",
        "rationale_token"
      ],
      "properties": {
        "selected_primary_backend": {
          "enum": ["js", "subtle"]
        },
        "selected_secondary_backend": {
          "enum": ["js", "subtle"]
        },
        "subtle_to_js_median_ratio": {
          "$ref": "#/$defs/nonnegative_number"
        },
        "ratio_threshold_met": {
          "type": "boolean"
        },
        "matched_pair_requirement_met": {
          "type": "boolean"
        },
        "prerequisites_met": {
          "type": "boolean"
        },
        "rationale_token": {
          "enum": [
            "subtle-materially-faster",
            "js-default-threshold-not-met"
          ]
        }
      }
    },
    "verdicts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correctness_passed",
        "responsiveness_passed",
        "environment_passed",
        "cleanup_passed",
        "schema_passed"
      ],
      "properties": {
        "correctness_passed": { "type": "boolean" },
        "responsiveness_passed": { "type": "boolean" },
        "environment_passed": { "type": "boolean" },
        "cleanup_passed": { "type": "boolean" },
        "schema_passed": { "type": "boolean" }
      }
    }
  }
}
